# ──────────────────────────────────────────────────────────
# Flash Sale Engine — Production Environment Variables
# Copy this to .env on your Oracle VM. NEVER commit .env.
# ──────────────────────────────────────────────────────────

# GitHub (for pulling images from GHCR)
GITHUB_REPO_OWNER=satyachandu11

# Database — use strong passwords in production
POSTGRES_DB=flashsale
POSTGRES_USER=flashsale_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis — require a password in production
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# URLs — replace with your actual domain
FRONTEND_URL=https://flashsale.yourdomain.in
ADMIN_FRONTEND_URL=https://admin.yourdomain.in
GRAFANA_URL=https://grafana.yourdomain.in

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Session TTLs
ADMIN_SESSION_TTL_SECONDS=28800
PUBLIC_ACCESS_SESSION_TTL_SECONDS=86400
INVITE_TTL_HOURS=24

# Internal secret for admin-service → inventory-service calls
ADMIN_SERVICE_INTERNAL_SECRET=CHANGE_ME_INTERNAL_SECRET

# Payment simulation
PAYMENT_GATEWAY_FAILURE_RATE=0.2

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Email (Resend.com — free up to 3000 emails/month)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@yourdomain.in
ADMIN_NOTIFICATION_EMAIL=you@yourdomain.in

# Managed product config
ADMIN_MANAGED_PRODUCT_ID=6ba7b810-9dad-11d1-80b4-00c04fd430c8
ADMIN_MANAGED_PRODUCT_NAME=Flash Sale Product
ADMIN_MANAGED_PRODUCT_DESCRIPTION=Limited stock flash sale item
ADMIN_MANAGED_PRODUCT_TOP_UP=100

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
