# Docker Compose reads this file automatically when copied to .env.
# The same variable names can also be exported in your shell for local Spring Boot runs.

POSTGRES_DB=flashsale
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_PORT=5432

KAFKA_PORT=9092
REDIS_PORT=6379
KAFKA_UI_PORT=8085
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

APP_CORS_ALLOWED_ORIGIN=http://localhost:5173
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/flashsale?TimeZone=UTC
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=admin
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

PAYMENT_GATEWAY_FAILURE_RATE=0.2
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

